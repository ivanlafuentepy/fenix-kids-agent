# AgentKit — Variables de entorno
# Copia este archivo como .env y llena tus datos:
#   cp .env.example .env
#
# Claude Code te ayuda a llenar estos valores durante el setup.
# NUNCA subas el archivo .env a GitHub.

# ── Anthropic API ──────────────────────────────────────────
# Obtener en: https://platform.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=
ANTHROPIC_API_KEY_AURORA=

# ── Proveedor de WhatsApp ──────────────────────────────────
# Opciones: whapi | meta | twilio
WHATSAPP_PROVIDER=meta

# ── Meta Cloud API (si WHATSAPP_PROVIDER=meta) ────────────
# Configurar en: https://developers.facebook.com
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=

# ── Servidor ──────────────────────────────────────────────
PORT=8000
ENVIRONMENT=development

# ── Base de datos ─────────────────────────────────────────
# Local (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./agentkit.db
# Produccion (PostgreSQL en Railway):
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ── Airtable ──────────────────────────────────────────────
# Personal Access Token: airtable.com/create/tokens
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ── Telegram (espejos y alertas) ──────────────────────────
# Crear bot en: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_GROUP_ID=
TELEGRAM_GROUP_ID_FLIAS=
TELEGRAM_MONITOR_GROUP_ID=

# ── AWS (servicios auxiliares) ────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# ── Google Calendar ───────────────────────────────────────
GOOGLE_CALENDAR_ID=
GOOGLE_CREDENTIALS_PATH=

# ── Groq (modelo alternativo) ────────────────────────────
GROQ_API_KEY=
